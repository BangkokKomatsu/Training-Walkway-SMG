# =============================================================================
# Data API - Node.js (.env.example)
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ environment ของบริษัทคุณ
# ห้าม commit .env ขึ้น Git เด็ดขาด
# =============================================================================

# ---- Database (MSSQL) ----
DB_SERVER=your-sql-server\INSTANCE
DB_PORT=1433
DB_NAME=your-database
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_DRIVER={ODBC Driver 17 for SQL Server}
DB_ENCRYPT=false
DB_TRUST_CERT=true

# ---- Server ----
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# ---- JWT Auth ----
# ตั้งเป็น string ยาว ๆ สุ่มเอง เช่น `openssl rand -hex 32`
JWT_SECRET=change-this-to-a-long-random-string-before-deploy
JWT_EXPIRES=8h

# ---- Detection image storage (โหมด local — ค่า default สำหรับทุกบริษัท) ----
# โฟลเดอร์ที่ Python เซฟรูป detection — data-api อ่านไฟล์จากที่นี่แล้ว stream ให้เว็บโดยตรง
# ต้องเป็น path เดียวกับ IMAGE_SHARED_DRIVE ฝั่ง Python (.env ที่ root)
# เช่น local: C:\DetectionImages  หรือ share ของบริษัท: \\your-server\share\walkway
IMAGE_SHARED_DRIVE=C:\DetectionImages

# ---- (เฉพาะ BKC) BKC image signed-URL service ----
# บริษัททั่วไป "ไม่ต้องตั้ง" 2 ค่านี้ — ปล่อยว่าง/คอมเมนต์ไว้ ระบบจะ stream รูปจาก
# IMAGE_SHARED_DRIVE เอง ตั้งเฉพาะเมื่อจะใช้ BKC image API (iapi.bkc.co.th) แทนการ serve ไฟล์ตรง
# BKC_IMAGE_API_URL=https://iapi.bkc.co.th/api/common/image/generate-url
# BKC_IMAGE_API_KEY=

# ---- Internal service auth (Python detection service → data-api) ----
# ป้องกัน endpoint /api/internal/* — ต้องเป็นค่าเดียวกับ INTERNAL_SERVICE_KEY ใน .env ฝั่ง Python
INTERNAL_SERVICE_KEY=change-this-to-a-long-random-string
