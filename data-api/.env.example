# =============================================================================
# Data API - Node.js (.env.example)
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ environment จริง
# ห้าม commit .env ขึ้น Git เด็ดขาด
# =============================================================================

# ---- Database (MSSQL) ----
DB_SERVER=BKCSR093\SQLPRO
DB_PORT=1433
DB_NAME=IOT
DB_USER=iotconnect
DB_PASSWORD=your-db-password-here
DB_ENCRYPT=false
DB_TRUST_CERT=true

# ---- Server ----
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# ---- JWT Auth ----
JWT_SECRET=change-this-to-a-long-random-string-before-deploy
JWT_EXPIRES=8h

# ---- BKC Image API (สำหรับ generate signed URL แสดงรูปใน frontend) ----
# ถ้าไม่ได้ตั้งค่า BKC_IMAGE_API_KEY ระบบจะ skip การแสดงรูป (training mode)
BKC_IMAGE_API_URL=https://iapi.bkc.co.th/api/common/image/generate-url
BKC_IMAGE_API_KEY=your-bkc-api-key-here
