# =============================================================================
# Walkway Detection System - Environment Variables (ตัวอย่าง)
# คัดลอกไฟล์นี้เป็น ".env" แล้วใส่ค่าจริงของตัวเอง
# ห้าม commit ไฟล์ .env ขึ้น Git เด็ดขาด
# =============================================================================

# ---- General ----
DEVICE=cpu                       # cuda | cpu
COMPANY_CODE=DEMO

# ---- Camera (RTSP) ----
# ใช้ path ไฟล์วิดีโอ (เช่น assets/sample-images/sample.mp4) แทนได้สำหรับทดสอบโดยไม่มีกล้องจริง
CAMERA_RTSP_URL=rtsp://user:pass@ip:554/Streaming/Channels/102
CAMERA_NO=1
CAMERA_NAME=Camera-1
LOCATION_NAME=อาคาร 1 ทางเดินสาย A

# ---- Detection (YOLO) ----
YOLO_MODEL_PATH=Models/yolo11n.pt
CONF_THRESHOLD=0.5

# ---- Walkway Danger Zone (polygon) ----
# พิกัดมุมของพื้นที่อันตรายบนภาพ รูปแบบ "x1,y1;x2,y2;x3,y3;..." (ต้องมีอย่างน้อย 3 จุด)
DANGER_ZONE_POLYGON=100,100;540,100;540,380;100,380

# ---- Event Logic (สองตัวจับเวลา อย่าสับสน) ----
# DWELL_SECONDS = อยู่ในพื้นที่อันตรายต่อเนื่องกี่วินาทีถึงนับเป็น event
DWELL_SECONDS=5
# ALERT_COOLDOWN_SECONDS = แจ้งเตือนแล้ว เว้นกี่วินาทีถึงแจ้งซ้ำของกล้องเดิม
ALERT_COOLDOWN_SECONDS=120

# ---- Database (MSSQL) ----
DB_DRIVER={ODBC Driver 17 for SQL Server}
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ---- Storage (Shared Drive สำหรับเซฟรูป) ----
IMAGE_SHARED_DRIVE=\\server\share\walkway-detection

# ---- Alert: Teams (Power Automate Workflows webhook, ฟรี/Standard) ----
TEAMS_WEBHOOK_URL=

# ---- Alert: Email (SMTP M365 - app password) ----
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
