# =============================================================================
# Walkway Detection System - Python (.env.example)
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ environment ของบริษัทคุณ
# ห้าม commit .env ขึ้น Git เด็ดขาด
# =============================================================================

# ---- General ----
DEVICE=cpu
# รหัสบริษัทของ deployment นี้ (แต่ละบริษัทตั้งของตัวเอง)
COMPANY_CODE=DEMO

# ---- Camera ----
# ตั้งค่ากล้องทั้งหมดใน config/cameras.json หรืออ่านจาก db
CAMERA_CONFIG_SOURCE=db
CAMERAS_CONFIG_PATH=config/cameras.json
CAMERA_RTSP_USER=admin
CAMERA_RTSP_PASSWORD=your-camera-password

SCHEDULE_SOURCE=db
MAX_CONCURRENT_CAMERAS=1
ROTATION_INTERVAL_SECONDS=60

# ---- Detection (YOLO) ----
YOLO_MODEL_PATH=Models/yolo11n.pt
CONF_THRESHOLD=0.2

# ---- Event Logic ----
# DWELL_SECONDS  = อยู่ในพื้นที่อันตรายต่อเนื่องกี่วินาทีถึงนับเป็น event
# ALERT_COOLDOWN = แจ้งเตือนแล้ว เว้นกี่วินาทีถึงแจ้งซ้ำของกล้องเดิม
DWELL_SECONDS=5
ALERT_COOLDOWN_SECONDS=120

# ---- Database (MSSQL) ----
DB_DRIVER={ODBC Driver 17 for SQL Server}
DB_SERVER=your-sql-server\INSTANCE
DB_NAME=your-database
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ---- Storage (โฟลเดอร์เซฟรูป detection — local หรือ share ของบริษัท) ----
# โครงสร้าง: {IMAGE_SHARED_DRIVE}\{company_code}\{camera_no}\{YYYYMMDD}\detection__{...}.jpg
# ต้องเป็น path เดียวกับ IMAGE_SHARED_DRIVE ใน data-api/.env
IMAGE_SHARED_DRIVE=C:\DetectionImages

# ---- Alert: Teams (Power Automate Workflows webhook) ----
ENABLE_TEAMS_ALERT=false
TEAMS_WEBHOOK_URL=

# ---- Alert: Email (SMTP M365 - app password) ----
ENABLE_EMAIL_ALERT=false
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=alert@yourcompany.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_TO=safety-team@yourcompany.com

# ---- data-api internal call (ขอ signed image URL ก่อนส่ง Teams alert — เฉพาะ BKC) ----
# INTERNAL_SERVICE_KEY ต้องตรงกับค่าใน data-api/.env
DATA_API_INTERNAL_URL=http://localhost:3001
INTERNAL_SERVICE_KEY=change-this-to-a-long-random-string
IMAGE_URL_TIMEOUT_SECONDS=3
